  </licenses>

  <developers>
    <developer>
      <name>yaosh</name>
      <email>7385697@qq.com</email>
      <organization></organization>
      <organizationUrl>https://github.com/jukejuke</organizationUrl>
    </developer>
  </developers>

  <scm>
    <connection>scm:git:https://github.com/jukejuke/jk-tool.git</connection>
    <developerConnection>scm:git:https://github.com/jukejuke/jk-tool.git</developerConnection>
    <url>https://github.com/jukejuke/jk-tool</url>
  </scm>

    <properties>
        <freemarker.version>2.3.34</freemarker.version>
        <!--<freemarker.version>2.3.32</freemarker.version>-->
        <nimbus-jose-jwt.version>10.6</nimbus-jose-jwt.version>
        <!-- <nimbus-jose-jwt.version>9.37</nimbus-jose-jwt.version>-->
        <fastjson2.version>2.0.61</fastjson2.version>
        <okhttp.version>4.12.0</okhttp.version>
        <lombok.version>1.18.42</lombok.version>
        <!--<lombok.version>1.18.24</lombok.version>-->
        <dnsjava.version>3.6.3</dnsjava.version>
        <javax.mail.version>1.6.2</javax.mail.version>
        <slf4j.version>1.7.36</slf4j.version>
        <qiniu.version>7.15.0</qiniu.version>
        <poi.version>5.3.0</poi.version>
        <junit.version>5.9.2</junit.version>
        <mockito.version>4.11.0</mockito.version>
        <maven-source-plugin.version>3.2.1</maven-source-plugin.version>
        <maven-compiler-plugin.version>3.2</maven-compiler-plugin.version>
        <maven-javadoc-plugin.version>3.3.1</maven-javadoc-plugin.version>
        <maven-gpg-plugin.version>1.6</maven-gpg-plugin.version>
        <central-publishing-maven-plugin.version>0.9.0</central-publishing-maven-plugin.version>
        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
    </properties>


  <build>
    <plugins>
      <!--   central发布插件    -->
      <plugin>
        <groupId>org.sonatype.central</groupId>
        <artifactId>central-publishing-maven-plugin</artifactId>
        <!--<version>0.4.0</version>-->
        <version>0.9.0</version>
        <extensions>true</extensions>
        <configuration>
          <publishingServerId>ossrh</publishingServerId>
          <!--<tokenAuth>true</tokenAuth>-->
          <autoPublish>false</autoPublish> <!-- 手动发布 -->
          <waitUntil>uploaded</waitUntil> <!-- 等待上传完成 -->
        </configuration>
      </plugin>
      <!--   source源码插件 -->
      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-source-plugin</artifactId>
        <version>3.2.1</version>
        <executions>
          <execution>
            <id>attach-sources</id>
            <goals>
              <goal>jar-no-fork</goal>
            </goals>
          </execution>
        </executions>
      </plugin>
      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-compiler-plugin</artifactId>
        <version>3.2</version>
        <!--<version>3.11.0</version>-->
        <configuration>
          <source>8</source>
          <target>8</target>
<!--          <source>8</source>
          <target>8</target>-->
          <encoding>UTF-8</encoding>
        </configuration>
      </plugin>
      <!--   javadoc插件 -->
      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-javadoc-plugin</artifactId>
        <version>3.3.1</version>
        <executions>
          <execution>
            <id>attach-javadocs</id>
            <goals>
              <goal>jar</goal>
            </goals>
          </execution>
        </executions>
      </plugin>
<!--      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-gpg-plugin</artifactId>
        <version>1.6</version> &lt;!&ndash; 升级到最新版（1.6 已过时） &ndash;&gt;
